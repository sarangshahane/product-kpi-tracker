{
	"name": "product-kpi-tracker",
	"version": "1.0.0",
	"description": "Track and analyze key performance indicators for your WooCommerce products",
	"main": "index.js",
	"scripts": {
		"start": "wp-scripts start",
		"build": "wp-scripts build",
		"i18n": "grunt textdomain && wp i18n make-pot languages/product-kpi-tracker.pot --domain=product-kpi-tracker --debug",
		"pretty": "prettier --check .",
		"pretty:fix": "prettier --write .",
		"lint-js": "wp-scripts lint-js",
		"lint-js:fix": "npm run pretty:fix && npm run lint-js -- --fix",
		"lint-css": "wp-scripts lint-style --allow-empty-input",
		"lint-css:fix": "npm run lint-css -- --fix",
		"lint-pkg-json": "wp-scripts lint-pkg-json",
		"packages-update": "wp-scripts packages-update",
		"check-engines": "wp-scripts check-engines",
		"check-licenses": "wp-scripts check-licenses",
		"format": "wp-scripts format",
		"lint:md:docs": "wp-scripts lint-md-docs",
		"lint:md:js": "wp-scripts lint-md-js",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"plugin-zip": "wp-scripts plugin-zip",
		"test:e2e": "wp-scripts test-e2e",
		"test:unit": "wp-scripts test-unit-js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/your-company/product-kpi-tracker.git"
	},
	"author": "Your Company Name",
	"license": "GPL-2.0-or-later",
	"bugs": {
		"url": "https://github.com/your-company/product-kpi-tracker/issues"
	},
	"homepage": "https://github.com/your-company/product-kpi-tracker#readme",
	"devDependencies": {
		"@wordpress/scripts": "^30.18.0",
		"grunt": "^1.4.1",
		"grunt-cli": "^1.4.3",
		"grunt-contrib-clean": "^2.0.0",
		"grunt-contrib-compress": "^2.0.0",
		"grunt-contrib-copy": "^1.0.0",
		"wp-prettier": "^2.6.2"
	}
}
